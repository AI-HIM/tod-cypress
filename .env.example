BASE_URL=https://todapp-dev.tynybay.com
USER_EMAIL=your-email@example.com
USER_PASSWORD=YourPassword
TEST_ENV=dev

# Optional: second test account for RBAC enforcement tests
# This user must already be invited and onboarded with a restricted role.
RESTRICTED_USER_EMAIL=restricted-user@example.com
RESTRICTED_USER_PASSWORD=RestrictedUserPassword

# Optional per-environment URL overrides, used by cypress.config.js as a
# fallback when BASE_URL above is not set. Not needed if BASE_URL is set.
# QA_BASE_URL=https://todapp-qa.tynybay.com
# STAGING_BASE_URL=https://todapp-staging.tynybay.com
# UAT_BASE_URL=https://todapp-uat.tynybay.com
